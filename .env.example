# ============================================================
# Sol Monitor — Environment Configuration
# ============================================================

# ── BirdEye API（必填）
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius API（预留）
HELIUS_API_KEY=your_helius_api_key_here

# ── 本服务监听端口
PORT=3003

# ── 交易机器人 Webhook
TRADE_BOT_HOST=localhost
TRADE_BOT_PORT=3002

# ── 代币监控参数
TOKEN_MAX_AGE_MINUTES=60
CANDLE_INTERVAL_SECONDS=5

# ── 白名单退出条件
FDV_MINIMUM=10000

# ── RSI 参数
RSI_PERIOD=7
RSI_BUY_CROSS=30
RSI_SELL_HIGH=80
RSI_SELL_CROSS=70
RE_ADD_DROP_PCT=20

# ── 止盈止损（百分比）
TP_PCT=50
SL_PCT=50

EMA_FILTER_RATIO=0.97

